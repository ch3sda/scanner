<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ThreatScan — IOC Intelligence Platform</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<style>
  :root {
    --bg:#0a0e1a;--bg2:#0f1525;--bg3:#151c2e;--bg4:#1a2338;
    --border:rgba(99,179,237,0.12);--border2:rgba(99,179,237,0.22);
    --text:#e2e8f0;--text2:#94a3b8;--text3:#64748b;
    --accent:#63b3ed;--accent2:#4299e1;
    --green:#68d391;--red:#fc8181;--yellow:#f6e05e;--orange:#f6ad55;--purple:#b794f4;--cyan:#76e4f7;
    --font:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;
    --mono:'JetBrains Mono','Fira Code',monospace;
    --radius:10px;--radius2:6px;
  }
  [data-theme="light"] {
    --bg:#f0f4f8;--bg2:#ffffff;--bg3:#f8fafc;--bg4:#e2e8f0;
    --border:rgba(37,99,235,0.12);--border2:rgba(37,99,235,0.25);
    --text:#0f172a;--text2:#475569;--text3:#94a3b8;
    --accent:#2563eb;--accent2:#1d4ed8;
    --green:#16a34a;--red:#dc2626;--yellow:#ca8a04;--orange:#ea580c;--purple:#7c3aed;--cyan:#0891b2;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:var(--font);background:var(--bg);color:var(--text);min-height:100vh;transition:background .3s,color .3s;font-size:14px;line-height:1.6;}
  /* LOGIN */
  #login-screen{position:fixed;inset:0;z-index:1000;background:var(--bg);display:flex;align-items:center;justify-content:center;flex-direction:column;}
  .login-card{background:var(--bg2);border:1px solid var(--border2);border-radius:16px;padding:48px 40px;width:100%;max-width:420px;text-align:center;}
  .login-logo{font-size:28px;font-weight:700;letter-spacing:-.5px;color:var(--accent);margin-bottom:4px;}
  .login-logo span{color:var(--text);}
  .login-subtitle{color:var(--text2);font-size:13px;margin-bottom:32px;}
  .login-label{display:block;text-align:left;font-size:12px;color:var(--text3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;margin-top:20px;}
  .login-input{width:100%;padding:12px 16px;background:var(--bg3);border:1px solid var(--border2);border-radius:var(--radius2);color:var(--text);font-size:15px;outline:none;transition:border-color .2s;font-family:var(--mono);}
  .login-input:focus{border-color:var(--accent);}
  .login-btn{width:100%;margin-top:28px;padding:13px;background:var(--accent);color:#fff;border:none;border-radius:var(--radius2);font-size:14px;font-weight:600;cursor:pointer;transition:opacity .2s,transform .1s;letter-spacing:.02em;}
  .login-btn:hover{opacity:.9;}.login-btn:active{transform:scale(.99);}
  .login-err{color:var(--red);font-size:12px;margin-top:10px;min-height:18px;}
  .login-hint{color:var(--text3);font-size:11px;margin-top:16px;}
  /* LAYOUT */
  #app{display:none;flex-direction:column;min-height:100vh;}
  header{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;backdrop-filter:blur(8px);}
  .logo{font-size:18px;font-weight:700;color:var(--accent);letter-spacing:-.5px;display:flex;align-items:center;gap:8px;}
  .logo .dot{width:8px;height:8px;border-radius:50%;background:var(--green);animation:pulse 2s infinite;}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
  .header-right{display:flex;align-items:center;gap:12px;}
  .theme-btn,.logout-btn{background:var(--bg3);border:1px solid var(--border);color:var(--text2);padding:6px 12px;border-radius:var(--radius2);cursor:pointer;font-size:12px;transition:all .2s;}
  .theme-btn:hover,.logout-btn:hover{border-color:var(--border2);color:var(--text);}
  .main{display:flex;flex:1;}
  nav{width:220px;min-width:220px;background:var(--bg2);border-right:1px solid var(--border);padding:20px 12px;display:flex;flex-direction:column;gap:4px;position:sticky;top:56px;height:calc(100vh - 56px);overflow-y:auto;}
  .nav-section{font-size:10px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;padding:12px 10px 6px;}
  .nav-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:var(--radius2);color:var(--text2);cursor:pointer;font-size:13px;transition:all .15s;border:1px solid transparent;}
  .nav-item:hover{background:var(--bg3);color:var(--text);}
  .nav-item.active{background:rgba(99,179,237,.1);color:var(--accent);border-color:rgba(99,179,237,.2);}
  .nav-icon{font-size:16px;width:18px;text-align:center;}
  .content{flex:1;padding:28px 32px;overflow-y:auto;max-width:100%;}
  .page{display:none;}.page.active{display:block;}
  /* SEARCH PANEL */
  .search-panel{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:28px;margin-bottom:24px;}
  .ioc-tabs{display:flex;gap:4px;margin-bottom:24px;background:var(--bg3);padding:4px;border-radius:8px;width:fit-content;}
  .ioc-tab{padding:7px 20px;border-radius:6px;cursor:pointer;font-size:13px;font-weight:500;color:var(--text2);transition:all .2s;border:none;background:transparent;}
  .ioc-tab.active{background:var(--bg2);color:var(--accent);box-shadow:0 1px 4px rgba(0,0,0,.2);}
  .search-row{display:flex;gap:10px;}
  .ioc-input{flex:1;padding:13px 18px;background:var(--bg3);border:1px solid var(--border2);border-radius:var(--radius2);color:var(--text);font-size:14px;font-family:var(--mono);outline:none;transition:border-color .2s;}
  .ioc-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(99,179,237,.1);}
  .ioc-textarea{width:100%;padding:13px 18px;background:var(--bg3);border:1px solid var(--border2);border-radius:var(--radius2);color:var(--text);font-size:13px;font-family:var(--mono);outline:none;transition:border-color .2s;resize:vertical;min-height:80px;line-height:1.6;}
  .ioc-textarea:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(99,179,237,.1);}
  .scan-btn{padding:13px 28px;background:var(--accent);color:#fff;border:none;border-radius:var(--radius2);cursor:pointer;font-size:14px;font-weight:600;transition:all .2s;white-space:nowrap;}
  .scan-btn:hover{background:var(--accent2);}.scan-btn:disabled{opacity:.5;cursor:not-allowed;}
  /* MULTI HINT */
  .multi-hint{font-size:12px;color:var(--text3);margin-top:8px;display:flex;align-items:center;gap:6px;}
  /* WARNING BANNER */
  .warn-banner{background:rgba(246,173,85,.1);border:1px solid rgba(246,173,85,.35);border-radius:var(--radius2);padding:10px 16px;font-size:13px;color:var(--orange);margin-top:10px;display:none;align-items:center;gap:8px;}
  /* BATCH PROGRESS */
  .batch-bar-wrap{margin-top:16px;display:none;}
  .batch-bar-track{height:4px;background:var(--bg4);border-radius:2px;overflow:hidden;margin-top:6px;}
  .batch-bar-fill{height:100%;background:var(--accent);border-radius:2px;transition:width .4s ease;}
  .batch-status{font-size:12px;color:var(--text2);margin-top:6px;}
  /* API KEY */
  .api-section{margin-top:20px;padding-top:20px;border-top:1px solid var(--border);display:flex;align-items:center;gap:10px;}
  .api-label{font-size:12px;color:var(--text3);white-space:nowrap;}
  .api-input{flex:1;padding:8px 14px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius2);color:var(--text2);font-size:13px;font-family:var(--mono);outline:none;}
  .api-input:focus{border-color:var(--accent);}
  .api-save{padding:8px 16px;background:var(--bg3);border:1px solid var(--border2);color:var(--accent);border-radius:var(--radius2);cursor:pointer;font-size:12px;}
  /* RESULTS */
  .result-area{margin-top:24px;}
  /* MULTI-RESULT TABS */
  .result-tabs{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:16px;}
  .result-tab{padding:5px 14px;border-radius:20px;font-size:12px;font-weight:500;cursor:pointer;border:1px solid var(--border2);background:var(--bg3);color:var(--text2);transition:all .15s;}
  .result-tab.active{background:var(--bg2);color:var(--accent);border-color:var(--accent);}
  .result-tab.malicious{border-color:rgba(252,129,129,.5);color:var(--red);}
  .result-tab.suspicious{border-color:rgba(246,173,85,.5);color:var(--orange);}
  .result-tab.clean{border-color:rgba(104,211,145,.4);color:var(--green);}
  .result-tab.active.malicious{background:rgba(252,129,129,.1);}
  .result-tab.active.suspicious{background:rgba(246,173,85,.1);}
  .result-tab.active.clean{background:rgba(104,211,145,.08);}
  .result-panel{display:none;}.result-panel.active{display:block;}
  /* VERDICT BANNER */
  .verdict-banner{border-radius:var(--radius);padding:20px 24px;margin-bottom:20px;display:flex;align-items:center;gap:16px;border:1px solid;}
  .verdict-banner.clean{background:rgba(104,211,145,.08);border-color:rgba(104,211,145,.3);}
  .verdict-banner.malicious{background:rgba(252,129,129,.08);border-color:rgba(252,129,129,.3);}
  .verdict-banner.suspicious{background:rgba(246,173,85,.08);border-color:rgba(246,173,85,.3);}
  .verdict-banner.unknown{background:rgba(100,116,139,.1);border-color:var(--border);}
  .verdict-icon{font-size:32px;}
  .verdict-title{font-size:20px;font-weight:700;}
  .verdict-sub{font-size:13px;color:var(--text2);margin-top:2px;}
  .verdict-stats{margin-left:auto;display:flex;gap:20px;text-align:center;}
  .vs-num{font-size:22px;font-weight:700;}.vs-lbl{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.05em;}
  /* GRID */
  .cards-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:16px;margin-bottom:20px;}
  .card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:20px;}
  .card-title{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:16px;display:flex;align-items:center;gap:6px;}
  /* GAUGE */
  .gauge-wrap{text-align:center;padding:8px 0;}
  .gauge-ring{position:relative;width:120px;height:120px;margin:0 auto 12px;}
  .gauge-svg{transform:rotate(-90deg);}
  .gauge-track{fill:none;stroke:var(--bg4);stroke-width:10;}
  .gauge-fill{fill:none;stroke-width:10;stroke-linecap:round;transition:stroke-dashoffset 1s ease;}
  .gauge-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
  .gauge-pct{font-size:26px;font-weight:700;}.gauge-lbl{font-size:10px;color:var(--text3);}
  /* META TABLE */
  .meta-table{width:100%;border-collapse:collapse;}
  .meta-table tr{border-bottom:1px solid var(--border);}
  .meta-table tr:last-child{border-bottom:none;}
  .meta-table td{padding:8px 0;font-size:13px;vertical-align:top;}
  .meta-table td:first-child{color:var(--text3);min-width:120px;font-size:11px;text-transform:uppercase;letter-spacing:.05em;padding-right:12px;}
  .meta-val{font-family:var(--mono);word-break:break-all;}
  /* ENGINES */
  .engine-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;max-height:280px;overflow-y:auto;}
  .engine-row{display:flex;align-items:center;gap:8px;padding:6px 10px;border-radius:6px;background:var(--bg3);font-size:12px;}
  .engine-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
  .engine-name{color:var(--text2);flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .engine-result{font-size:11px;font-family:var(--mono);}
  /* TAGS */
  .tag-list{display:flex;flex-wrap:wrap;gap:6px;}
  .tag{padding:3px 10px;border-radius:20px;font-size:11px;border:1px solid;font-weight:500;}
  .tag.red{background:rgba(252,129,129,.1);border-color:rgba(252,129,129,.3);color:var(--red);}
  .tag.green{background:rgba(104,211,145,.1);border-color:rgba(104,211,145,.3);color:var(--green);}
  .tag.blue{background:rgba(99,179,237,.1);border-color:rgba(99,179,237,.2);color:var(--accent);}
  .tag.gray{background:var(--bg3);border-color:var(--border);color:var(--text3);}
  .tag.orange{background:rgba(246,173,85,.1);border-color:rgba(246,173,85,.3);color:var(--orange);}
  /* MAP */
  #ip-map{height:480px;border-radius:var(--radius);border:1px solid var(--border);overflow:hidden;background:var(--bg3);margin-bottom:20px;}
  .leaflet-container{background:#0a0e1a !important;}
  [data-theme="light"] .leaflet-container{background:#c8d8e8 !important;}
  /* MAP LEGEND */
  .map-legend{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius2);padding:12px 16px;margin-bottom:16px;display:flex;gap:20px;align-items:center;flex-wrap:wrap;}
  .legend-item{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);}
  .legend-dot{width:12px;height:12px;border-radius:50%;}
  .legend-country{width:16px;height:10px;border-radius:2px;opacity:.7;}
  /* LOADING */
  .scan-loader{text-align:center;padding:48px;display:none;}
  .spin{width:40px;height:40px;border-radius:50%;border:3px solid var(--bg4);border-top-color:var(--accent);animation:spin .8s linear infinite;margin:0 auto 16px;}
  @keyframes spin{to{transform:rotate(360deg)}}
  .scan-msg{color:var(--text2);font-size:14px;}
  /* HISTORY */
  .history-list{display:flex;flex-direction:column;gap:8px;}
  .history-item{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius2);padding:12px 16px;display:flex;align-items:center;gap:12px;cursor:pointer;transition:border-color .2s;}
  .history-item:hover{border-color:var(--border2);}
  .history-ioc{font-family:var(--mono);font-size:12px;color:var(--text2);flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .history-type{font-size:10px;padding:2px 8px;border-radius:20px;background:var(--bg3);color:var(--text3);font-weight:600;text-transform:uppercase;letter-spacing:.05em;}
  .history-verdict{font-size:11px;font-weight:600;}
  .history-date{font-size:11px;color:var(--text3);white-space:nowrap;}
  /* STATS */
  .stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:16px;margin-bottom:24px;}
  .stat-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:20px;}
  .stat-num{font-size:28px;font-weight:700;}.stat-lbl{font-size:12px;color:var(--text3);margin-top:4px;}
  /* EMPTY */
  .empty-state{text-align:center;padding:60px 20px;color:var(--text3);}
  .empty-icon{font-size:48px;margin-bottom:12px;opacity:.4;}
  /* TOAST */
  .toast{position:fixed;bottom:24px;right:24px;background:var(--bg2);border:1px solid var(--border2);color:var(--text);padding:12px 20px;border-radius:var(--radius2);font-size:13px;z-index:9999;opacity:0;transform:translateY(8px);transition:all .3s;max-width:340px;}
  .toast.show{opacity:1;transform:translateY(0);}
  /* BARS */
  .cat-bar-wrap{margin-top:12px;}
  .cat-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
  .cat-bar-lbl{font-size:11px;color:var(--text2);width:90px;text-align:right;flex-shrink:0;}
  .cat-bar-track{flex:1;height:6px;background:var(--bg4);border-radius:3px;overflow:hidden;}
  .cat-bar-fill{height:100%;border-radius:3px;transition:width .8s ease;}
  .cat-bar-num{font-size:11px;color:var(--text3);width:24px;text-align:right;}
  /* GEO */
  .geo-info{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:12px;}
  .geo-chip{background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:10px 14px;}
  .geo-chip-lbl{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.05em;}
  .geo-chip-val{font-size:14px;font-weight:600;margin-top:3px;}
  /* FILE DROP */
  .file-drop{border:2px dashed var(--border2);border-radius:var(--radius);padding:40px;text-align:center;cursor:pointer;transition:border-color .2s;margin-top:16px;color:var(--text3);font-size:14px;}
  .file-drop:hover{border-color:var(--accent);color:var(--accent);}
  .file-drop input{display:none;}
  /* SCROLLBAR */
  ::-webkit-scrollbar{width:6px;height:6px;}
  ::-webkit-scrollbar-track{background:transparent;}
  ::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:3px;}
  @media(max-width:768px){nav{display:none;}.content{padding:16px;}.verdict-stats{display:none;}header{padding:0 16px;}.search-row{flex-direction:column;}.cards-grid{grid-template-columns:1fr;}}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-card">
    <div class="login-logo">Threat<span>Scan</span></div>
    <div class="login-subtitle">IOC Intelligence Platform · Authorized Access Only</div>
    <label class="login-label">Security Passphrase</label>
    <input type="password" class="login-input" id="login-input" placeholder="Enter security phrase…" autocomplete="off">
    <div class="login-err" id="login-err"></div>
    <button class="login-btn" onclick="doLogin()">Authenticate →</button>
    <div class="login-hint">This platform is restricted. Unauthorized access is prohibited.</div>
  </div>
</div>

<!-- APP -->
<div id="app">
  <header>
    <div class="logo"><div class="dot"></div>ThreatScan</div>
    <div class="header-right">
      <span style="font-size:12px;color:var(--text3)" id="header-user"></span>
      <button class="theme-btn" onclick="toggleTheme()" id="theme-btn">🌙 Dark</button>
      <button class="logout-btn" onclick="doLogout()">Sign Out</button>
    </div>
  </header>
  <div class="main">
    <nav>
      <div class="nav-section">Analyze</div>
      <div class="nav-item active" onclick="showPage('scan')" id="nav-scan"><span class="nav-icon">🔍</span> Scan IOC</div>
      <div class="nav-item" onclick="showPage('history')" id="nav-history"><span class="nav-icon">📋</span> History</div>
      <div class="nav-section">Intel</div>
      <div class="nav-item" onclick="showPage('dashboard')" id="nav-dashboard"><span class="nav-icon">📊</span> Dashboard</div>
      <div class="nav-item" onclick="showPage('ipmap')" id="nav-ipmap"><span class="nav-icon">🗺️</span> IP Map</div>
      <div class="nav-section">Config</div>
      <div class="nav-item" onclick="showPage('settings')" id="nav-settings"><span class="nav-icon">⚙️</span> Settings</div>
    </nav>
    <div class="content">

      <!-- SCAN PAGE -->
      <div class="page active" id="page-scan">
        <div class="search-panel">
          <div style="margin-bottom:20px">
            <h2 style="font-size:18px;font-weight:700;margin-bottom:4px">IOC Scanner</h2>
            <p style="font-size:13px;color:var(--text2)">Submit one or multiple IOCs separated by commas. Supports IP addresses, file hashes, and URLs.</p>
          </div>
          <div class="ioc-tabs">
            <button class="ioc-tab active" onclick="setType('ip')" id="tab-ip">🌐 IP Address</button>
            <button class="ioc-tab" onclick="setType('hash')" id="tab-hash">#️⃣ Hash</button>
            <button class="ioc-tab" onclick="setType('url')" id="tab-url">🔗 URL</button>
            <button class="ioc-tab" onclick="setType('file')" id="tab-file">📄 File</button>
          </div>

          <div id="input-area">
            <textarea class="ioc-textarea" id="ioc-input" placeholder="Enter one or multiple IPs separated by commas…&#10;e.g. 185.220.101.45, 8.8.8.8, 1.1.1.1" oninput="onIOCInput(this.value)"></textarea>
            <div class="multi-hint" id="multi-hint">
              <span>💡 Separate multiple IOCs with commas</span>
              <span id="ioc-count" style="margin-left:auto;color:var(--accent);font-weight:500"></span>
            </div>
            <div class="warn-banner" id="warn-banner">
              ⚠️ <span>You're scanning <strong id="warn-count">0</strong> IOCs at once. This will consume multiple API requests from your daily quota (500/day free). Proceed with care.</span>
            </div>
            <div style="margin-top:12px">
              <button class="scan-btn" id="scan-btn" onclick="doScan()">Scan →</button>
            </div>
          </div>

          <div id="file-area" style="display:none">
            <div class="file-drop" onclick="document.getElementById('file-input').click()">
              <input type="file" id="file-input" onchange="handleFile(this)">
              <div style="font-size:32px;margin-bottom:8px">📁</div>
              <div>Drop file here or click to browse</div>
              <div style="font-size:12px;margin-top:6px">File will be hashed (SHA-256) and submitted to VirusTotal</div>
            </div>
          </div>

          <!-- BATCH PROGRESS -->
          <div class="batch-bar-wrap" id="batch-bar-wrap">
            <div class="batch-status" id="batch-status">Scanning 0 / 0…</div>
            <div class="batch-bar-track"><div class="batch-bar-fill" id="batch-bar-fill" style="width:0%"></div></div>
          </div>

          <div class="api-section">
            <span class="api-label">🔑 VT API Key</span>
            <input class="api-input" type="password" id="api-key-input" placeholder="Paste your VirusTotal API key…">
            <button class="api-save" onclick="saveApiKey()">Save</button>
          </div>
        </div>

        <div class="scan-loader" id="scan-loader">
          <div class="spin"></div>
          <div class="scan-msg" id="scan-msg">Querying VirusTotal…</div>
        </div>

        <div class="result-area" id="result-area"></div>
      </div>

      <!-- HISTORY -->
      <div class="page" id="page-history">
        <h2 style="font-size:18px;font-weight:700;margin-bottom:20px">Scan History</h2>
        <div class="history-list" id="history-list"></div>
      </div>

      <!-- DASHBOARD -->
      <div class="page" id="page-dashboard">
        <h2 style="font-size:18px;font-weight:700;margin-bottom:20px">Dashboard</h2>
        <div class="stats-grid" id="dash-stats"></div>
        <div class="cards-grid" id="dash-charts"></div>
      </div>

      <!-- IP MAP -->
      <div class="page" id="page-ipmap">
        <h2 style="font-size:18px;font-weight:700;margin-bottom:8px">IP Threat Map</h2>
        <p style="font-size:13px;color:var(--text2);margin-bottom:16px">Countries highlighted based on scanned IPs. Red = malicious activity detected, green = clean, orange = mixed.</p>
        <div class="map-legend">
          <div class="legend-item"><div class="legend-country" style="background:#fc8181"></div> Malicious country</div>
          <div class="legend-item"><div class="legend-country" style="background:#f6ad55"></div> Suspicious / mixed</div>
          <div class="legend-item"><div class="legend-country" style="background:#68d391"></div> Clean country</div>
          <div class="legend-item"><div class="legend-dot" style="background:#fc8181;border:2px solid #fff"></div> Malicious IP point</div>
          <div class="legend-item"><div class="legend-dot" style="background:#68d391;border:2px solid #fff"></div> Clean IP point</div>
        </div>
        <div id="ip-map"></div>
        <div style="margin-top:20px">
          <h3 style="font-size:14px;font-weight:600;color:var(--text2);margin-bottom:12px">Scanned IPs</h3>
          <div id="ip-list" class="history-list"></div>
        </div>
      </div>

      <!-- SETTINGS -->
      <div class="page" id="page-settings">
        <h2 style="font-size:18px;font-weight:700;margin-bottom:24px">Settings</h2>
        <div class="card" style="max-width:600px;margin-bottom:16px">
          <div class="card-title">🔑 API Configuration</div>
          <label class="login-label" style="margin-top:0">VirusTotal API Key</label>
          <input class="ioc-input" type="password" id="settings-api-key" placeholder="Paste your VirusTotal API key…" style="margin-bottom:12px">
          <button class="scan-btn" style="padding:10px 20px;font-size:13px" onclick="saveApiKeyFromSettings()">Save Key</button>
          <p style="font-size:12px;color:var(--text3);margin-top:12px">Free VT accounts: 4 requests/min, 500/day. Each IOC in a multi-scan uses one request.</p>
        </div>
        <div class="card" style="max-width:600px;margin-bottom:16px">
          <div class="card-title">🔒 Access Control</div>
          <label class="login-label" style="margin-top:0">Change Security Passphrase</label>
          <input class="ioc-input" type="password" id="new-pass" placeholder="New passphrase…" style="margin-bottom:10px">
          <input class="ioc-input" type="password" id="new-pass2" placeholder="Confirm passphrase…" style="margin-bottom:12px">
          <button class="scan-btn" style="padding:10px 20px;font-size:13px" onclick="changePass()">Update Passphrase</button>
        </div>
        <div class="card" style="max-width:600px">
          <div class="card-title">🗑️ Data</div>
          <button onclick="clearHistory()" style="padding:10px 20px;background:rgba(252,129,129,.1);border:1px solid rgba(252,129,129,.3);color:var(--red);border-radius:var(--radius2);cursor:pointer;font-size:13px">Clear All History</button>
        </div>
      </div>

    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ── STATE ──────────────────────────────────────────────────────────────────────
let currentType = 'ip';
let scanHistory = JSON.parse(localStorage.getItem('vt_history') || '[]');
let mapInstance = null;
let mapLayers = [];
let geoJsonLayer = null;
let isDark = true;
const DEFAULT_PASS_HASH = btoa('cheeseip');

// ── AUTH ───────────────────────────────────────────────────────────────────────
function getPassHash() { return localStorage.getItem('vt_pass') || DEFAULT_PASS_HASH; }
document.getElementById('login-input').addEventListener('keydown', e => { if(e.key==='Enter') doLogin(); });

function doLogin() {
  const val = document.getElementById('login-input').value;
  if (btoa(val) === getPassHash()) {
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('app').style.display = 'flex';
    const k = localStorage.getItem('vt_api_key') || '';
    document.getElementById('api-key-input').value = k;
    document.getElementById('settings-api-key').value = k;
    renderHistory(); renderDashboard();
    document.getElementById('header-user').textContent = '🔐 Authenticated';
  } else {
    document.getElementById('login-err').textContent = 'Incorrect passphrase. Access denied.';
    document.getElementById('login-input').value = '';
  }
}
function doLogout() {
  document.getElementById('login-screen').style.display='flex';
  document.getElementById('app').style.display='none';
  document.getElementById('login-input').value='';
  document.getElementById('login-err').textContent='';
}
function changePass() {
  const p1=document.getElementById('new-pass').value, p2=document.getElementById('new-pass2').value;
  if (!p1) return toast('Enter a passphrase.');
  if (p1!==p2) return toast('Passphrases do not match.');
  localStorage.setItem('vt_pass', btoa(p1));
  toast('✅ Passphrase updated.');
  document.getElementById('new-pass').value=''; document.getElementById('new-pass2').value='';
}

// ── THEME ──────────────────────────────────────────────────────────────────────
function toggleTheme() {
  isDark = !isDark;
  document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
  document.getElementById('theme-btn').textContent = isDark ? '🌙 Dark' : '☀️ Light';
  if (mapInstance) { refreshMapTiles(); }
}

// ── NAV ────────────────────────────────────────────────────────────────────────
function showPage(name) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  document.getElementById('nav-'+name).classList.add('active');
  if (name==='ipmap') setTimeout(initMap, 50);
  if (name==='history') renderHistory();
  if (name==='dashboard') renderDashboard();
}

// ── IOC TYPE ───────────────────────────────────────────────────────────────────
function setType(type) {
  currentType = type;
  document.querySelectorAll('.ioc-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab-'+type).classList.add('active');
  const ph = {
    ip:'Enter one or multiple IPs separated by commas…\ne.g. 185.220.101.45, 8.8.8.8, 1.1.1.1',
    hash:'Enter one or multiple hashes (MD5/SHA1/SHA256)…\ne.g. abc123…, def456…',
    url:'Enter one or multiple URLs separated by commas…\ne.g. https://evil.com, https://phish.net/path'
  };
  if (type==='file') {
    document.getElementById('input-area').style.display='none';
    document.getElementById('file-area').style.display='block';
  } else {
    document.getElementById('input-area').style.display='block';
    document.getElementById('file-area').style.display='none';
    document.getElementById('ioc-input').placeholder = ph[type] || '';
    document.getElementById('ioc-input').value = '';
    document.getElementById('ioc-count').textContent = '';
    document.getElementById('warn-banner').style.display='none';
  }
  document.getElementById('result-area').innerHTML='';
}

// ── MULTI IOC INPUT ────────────────────────────────────────────────────────────
function parseIOCs(raw) {
  return raw.split(',').map(s=>s.trim()).filter(s=>s.length>0);
}
function onIOCInput(val) {
  const iocs = parseIOCs(val);
  const count = iocs.length;
  const countEl = document.getElementById('ioc-count');
  const warnEl = document.getElementById('warn-banner');
  const warnCount = document.getElementById('warn-count');
  if (count > 1) {
    countEl.textContent = count + ' IOC' + (count>1?'s':'') + ' detected';
  } else {
    countEl.textContent = '';
  }
  if (count > 4) {
    warnEl.style.display='flex';
    warnCount.textContent = count;
  } else {
    warnEl.style.display='none';
  }
}

// ── API KEY ────────────────────────────────────────────────────────────────────
function getApiKey() { return localStorage.getItem('vt_api_key') || ''; }
function saveApiKey() {
  const k = document.getElementById('api-key-input').value.trim();
  if (k) { localStorage.setItem('vt_api_key', k); document.getElementById('settings-api-key').value=k; toast('✅ API key saved.'); }
}
function saveApiKeyFromSettings() {
  const k = document.getElementById('settings-api-key').value.trim();
  if (k) { localStorage.setItem('vt_api_key', k); document.getElementById('api-key-input').value=k; toast('✅ API key saved.'); }
}

// ── FILE ───────────────────────────────────────────────────────────────────────
async function handleFile(input) {
  const file = input.files[0]; if (!file) return;
  const hash = await sha256File(file);
  setType('hash');
  document.getElementById('ioc-input').value = hash;
  onIOCInput(hash);
  toast('📄 SHA-256: ' + hash.slice(0,16) + '…');
}
async function sha256File(file) {
  const buf = await file.arrayBuffer();
  const digest = await crypto.subtle.digest('SHA-256', buf);
  return Array.from(new Uint8Array(digest)).map(b=>b.toString(16).padStart(2,'0')).join('');
}

// ── SCAN ───────────────────────────────────────────────────────────────────────
async function doScan() {
  const raw = document.getElementById('ioc-input').value.trim();
  if (!raw) return toast('Enter an IOC to scan.');
  const apiKey = getApiKey();
  if (!apiKey) return toast('⚠️ Set your VirusTotal API key first.');

  const iocs = parseIOCs(raw);
  if (iocs.length === 0) return toast('No valid IOCs found.');

  // Show batch progress
  setBatchProgress(0, iocs.length);
  showLoader(true, iocs.length > 1 ? `Scanning 1 of ${iocs.length}…` : 'Querying VirusTotal…');
  document.getElementById('result-area').innerHTML = '';

  const results = [];
  for (let i = 0; i < iocs.length; i++) {
    if (i > 0) await sleep(1200); // rate limit buffer ~4req/min safe
    setBatchProgress(i + 1, iocs.length);
    document.getElementById('scan-msg').textContent = `Scanning ${i+1} of ${iocs.length}: ${iocs[i].slice(0,30)}…`;
    try {
      const data = await vtFetch(iocs[i], currentType, apiKey);
      const rec = processResult(iocs[i], currentType, data);
      addToHistory(rec);
      results.push({ ioc: iocs[i], rec, data });
    } catch(e) {
      results.push({ ioc: iocs[i], rec: null, error: e.message });
    }
  }

  showLoader(false);
  hideBatchProgress();
  renderMultiResult(results);
}

async function vtFetch(ioc, type, apiKey) {
  let endpoint = '';
  if (type==='ip') endpoint = `https://www.virustotal.com/api/v3/ip_addresses/${encodeURIComponent(ioc)}`;
  else if (type==='hash') endpoint = `https://www.virustotal.com/api/v3/files/${encodeURIComponent(ioc)}`;
  else if (type==='url') {
    const id = btoa(ioc).replace(/=/g,'');
    endpoint = `https://www.virustotal.com/api/v3/urls/${id}`;
  }
  const resp = await fetch(endpoint, { headers: {'x-apikey': apiKey} });
  const data = await resp.json();
  if (resp.status===401) throw new Error('Invalid API key.');
  if (resp.status===404) throw new Error('Not found in VirusTotal.');
  if (resp.status===429) throw new Error('Rate limit exceeded. Wait a minute.');
  if (!resp.ok) throw new Error(data.error?.message || 'API error ' + resp.status);
  return data;
}

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

function setBatchProgress(done, total) {
  if (total <= 1) return;
  const wrap = document.getElementById('batch-bar-wrap');
  wrap.style.display = 'block';
  document.getElementById('batch-status').textContent = `Scanning ${done} / ${total} IOCs…`;
  document.getElementById('batch-bar-fill').style.width = Math.round((done/total)*100) + '%';
}
function hideBatchProgress() {
  document.getElementById('batch-bar-wrap').style.display = 'none';
}

// ── PROCESS ───────────────────────────────────────────────────────────────────
function processResult(ioc, type, data) {
  const attrs = data.data?.attributes || {};
  const stats = attrs.last_analysis_stats || {};
  const malicious = stats.malicious || 0;
  const suspicious = stats.suspicious || 0;
  const total = Object.values(stats).reduce((a,b)=>a+b, 0);
  let verdict = 'unknown';
  if (total > 0) {
    if (malicious >= 3) verdict = 'malicious';
    else if (malicious >= 1 || suspicious >= 3) verdict = 'suspicious';
    else verdict = 'clean';
  }
  console.log("VT Country:", attrs.country);
  const country = attrs.country || null;
  return { ioc, type, verdict, malicious, suspicious, total, attrs, stats, country, timestamp: Date.now() };
}

// ── MULTI RESULT RENDER ───────────────────────────────────────────────────────
function renderMultiResult(results) {
  const container = document.getElementById('result-area');
  if (results.length === 1) {
    const r = results[0];
    if (r.error) {
      container.innerHTML = `<div class="verdict-banner unknown"><div class="verdict-icon">❌</div><div><div class="verdict-title">Scan Failed</div><div class="verdict-sub">${r.error}</div></div></div>`;
    } else {
      renderSingleResult(r.rec, r.data, 'result-area');
    }
    return;
  }

  // Multi: tabs + panels
  let tabsHtml = '<div class="result-tabs" id="result-tabs">';
  let panelsHtml = '';

  results.forEach((r, i) => {
    const short = r.ioc.length > 22 ? r.ioc.slice(0,10)+'…'+r.ioc.slice(-8) : r.ioc;
    const vClass = r.error ? 'gray' : (r.rec?.verdict || 'unknown');
    const vIcon = r.error ? '❌' : {malicious:'🔴',suspicious:'🟠',clean:'🟢',unknown:'❓'}[r.rec?.verdict] || '❓';
    tabsHtml += `<div class="result-tab ${vClass} ${i===0?'active':''}" onclick="switchResultTab(${i})" id="rtab-${i}">${vIcon} ${short}</div>`;
    panelsHtml += `<div class="result-panel ${i===0?'active':''}" id="rpanel-${i}"></div>`;
  });

  tabsHtml += '</div>';
  container.innerHTML = tabsHtml + panelsHtml;

  // Fill each panel
  results.forEach((r, i) => {
    if (r.error) {
      document.getElementById('rpanel-'+i).innerHTML = `<div class="verdict-banner unknown"><div class="verdict-icon">❌</div><div><div class="verdict-title">Scan Failed</div><div class="verdict-sub">${r.error}</div></div></div>`;
    } else {
      renderSingleResult(r.rec, r.data, 'rpanel-'+i);
    }
  });
}

function switchResultTab(idx) {
  document.querySelectorAll('.result-tab').forEach((t,i) => t.classList.toggle('active', i===idx));
  document.querySelectorAll('.result-panel').forEach((p,i) => p.classList.toggle('active', i===idx));
}

function renderSingleResult(rec, raw, containerId) {
  const attrs = rec.attrs;
  const stats = rec.stats;
  const engines = attrs.last_analysis_results || {};
  const el = document.getElementById(containerId);

  const vLabels = {malicious:'🚨 Malicious',suspicious:'⚠️ Suspicious',clean:'✅ Clean',unknown:'❓ Unknown'};
  const vDesc = {
    malicious:`${rec.malicious} of ${rec.total} engines flagged this IOC as malicious.`,
    suspicious:`${rec.suspicious} engines flagged as suspicious. Treat with caution.`,
    clean:`No engines flagged this IOC. Appears benign.`,
    unknown:'No scan data available in VirusTotal.'
  };
  const vColor = {malicious:'var(--red)',suspicious:'var(--orange)',clean:'var(--green)',unknown:'var(--text3)'};

  const pct = rec.total > 0 ? Math.round((rec.malicious/rec.total)*100) : 0;
  const r50=50, circ=2*Math.PI*r50;
  const offset = circ - (pct/100)*circ;
  const gc = rec.verdict==='malicious'?'#fc8181':rec.verdict==='suspicious'?'#f6ad55':rec.verdict==='clean'?'#68d391':'#64748b';
  const uid = containerId + '_' + Date.now();

  let html = `
    <div class="verdict-banner ${rec.verdict}">
      <div class="verdict-icon">${rec.verdict==='malicious'?'🚨':rec.verdict==='suspicious'?'⚠️':rec.verdict==='clean'?'✅':'❓'}</div>
      <div>
        <div class="verdict-title" style="color:${vColor[rec.verdict]}">${vLabels[rec.verdict]}</div>
        <div class="verdict-sub">${vDesc[rec.verdict]}</div>
      </div>
      <div class="verdict-stats">
        <div><div class="vs-num" style="color:var(--red)">${rec.malicious}</div><div class="vs-lbl">Malicious</div></div>
        <div><div class="vs-num" style="color:var(--orange)">${stats.suspicious||0}</div><div class="vs-lbl">Suspicious</div></div>
        <div><div class="vs-num" style="color:var(--green)">${stats.harmless||0}</div><div class="vs-lbl">Harmless</div></div>
        <div><div class="vs-num" style="color:var(--text3)">${rec.total}</div><div class="vs-lbl">Engines</div></div>
      </div>
    </div>
    <div class="cards-grid">
      <div class="card">
        <div class="card-title">📡 Detection Rate</div>
        <div class="gauge-wrap">
          <div class="gauge-ring">
            <svg class="gauge-svg" width="120" height="120" viewBox="0 0 120 120">
              <circle class="gauge-track" cx="60" cy="60" r="${r50}"/>
              <circle class="gauge-fill" cx="60" cy="60" r="${r50}" stroke="${gc}"
                stroke-dasharray="${circ.toFixed(1)}" stroke-dashoffset="${offset.toFixed(1)}" id="gf-${uid}"/>
            </svg>
            <div class="gauge-center">
              <div class="gauge-pct" style="color:${gc}">${pct}%</div>
              <div class="gauge-lbl">Detection</div>
            </div>
          </div>
          <div class="cat-bar-wrap">
            ${[['Malicious',rec.malicious,'#fc8181'],['Suspicious',stats.suspicious||0,'#f6ad55'],['Harmless',stats.harmless||0,'#68d391'],['Undetected',stats.undetected||0,'#64748b'],['Timeout',stats.timeout||0,'#b794f4']].map(([l,v,c])=>`
            <div class="cat-bar-row">
              <div class="cat-bar-lbl">${l}</div>
              <div class="cat-bar-track"><div class="cat-bar-fill" style="width:${rec.total>0?Math.round((v/rec.total)*100):0}%;background:${c}"></div></div>
              <div class="cat-bar-num">${v}</div>
            </div>`).join('')}
          </div>
        </div>
      </div>
      <div class="card">
        <div class="card-title">📋 Metadata</div>
        <table class="meta-table">${buildMetaRows(rec.type, attrs, rec.ioc).map(([k,v])=>`<tr><td>${k}</td><td class="meta-val">${v||'<span style="color:var(--text3)">—</span>'}</td></tr>`).join('')}</table>
      </div>`;

  // Tags
  const catTags = attrs.categories || {};
  const tags = attrs.tags || [];
  const threat = attrs.popular_threat_classification?.suggested_threat_label || null;
  if (Object.keys(catTags).length || tags.length || threat) {
    html += `<div class="card"><div class="card-title">🏷️ Categories & Tags</div><div class="tag-list">
      ${threat ? `<span class="tag red">🎯 ${threat}</span>` : ''}
      ${tags.map(t=>`<span class="tag orange">${t}</span>`).join('')}
      ${Object.values(catTags).slice(0,6).map(c=>`<span class="tag blue">${c}</span>`).join('')}
    </div></div>`;
  }

  // IP Geo
  if (rec.type==='ip') {
    html += `<div class="card"><div class="card-title">🌍 Geolocation</div>
      <div class="geo-info">
        <div class="geo-chip"><div class="geo-chip-lbl">Country</div><div class="geo-chip-val">${attrs.country||'—'}</div></div>
        <div class="geo-chip"><div class="geo-chip-lbl">Continent</div><div class="geo-chip-val">${attrs.continent||'—'}</div></div>
        <div class="geo-chip"><div class="geo-chip-lbl">ASN</div><div class="geo-chip-val">AS${attrs.asn||'—'}</div></div>
        <div class="geo-chip"><div class="geo-chip-lbl">Network</div><div class="geo-chip-val" style="font-size:12px">${attrs.network||'—'}</div></div>
      </div>
      <div style="margin-top:12px;font-size:12px;color:var(--text2)">${attrs.as_owner||''}</div>
    </div>`;
  }

  html += `</div>`;

  // Engines
  const eKeys = Object.keys(engines);
  if (eKeys.length) {
    const order = {malicious:0,suspicious:1,undetected:2,harmless:3,'type-unsupported':4,timeout:5};
    const sorted = eKeys.sort((a,b)=>(order[engines[a].category]??9)-(order[engines[b].category]??9));
    html += `<div class="card" style="margin-top:0">
      <div class="card-title">🛡️ Engine Results <span style="color:var(--text3);font-weight:400;text-transform:none;font-size:12px">(${eKeys.length} engines)</span></div>
      <div class="engine-grid">${sorted.map(name=>{
        const e=engines[name];
        const c=e.category==='malicious'?'#fc8181':e.category==='suspicious'?'#f6ad55':e.category==='harmless'?'#68d391':'#64748b';
        const ic=e.category==='malicious'?'🔴':e.category==='suspicious'?'🟠':e.category==='harmless'?'🟢':'⚪';
        return `<div class="engine-row" title="${name}: ${e.result||e.category}"><div class="engine-dot" style="background:${c}"></div><div class="engine-name">${name}</div><div class="engine-result" style="color:${c}">${ic} ${e.result?e.result.slice(0,18):e.category}</div></div>`;
      }).join('')}</div>
    </div>`;
  }

  html += `<div style="margin-top:12px;text-align:right">
    <a href="https://www.virustotal.com/gui/${rec.type==='ip'?'ip-address':rec.type==='hash'?'file':'url'}/${encodeURIComponent(rec.ioc)}"
       target="_blank" style="font-size:12px;color:var(--accent)">View full report on VirusTotal ↗</a>
  </div>`;

  el.innerHTML = html;
}

function buildMetaRows(type, attrs, ioc) {
  if (type==='ip') return [
    ['IP',`<span style="color:var(--accent)">${ioc}</span>`],
    ['Country',attrs.country||null],['AS Owner',attrs.as_owner||null],
    ['Network',attrs.network||null],['RIR',attrs.regional_internet_registry||null],
    ['Last Analysis',attrs.last_analysis_date?new Date(attrs.last_analysis_date*1000).toLocaleString():null],
    ['Reputation',attrs.reputation!==undefined?(attrs.reputation>0?`<span style="color:var(--green)">${attrs.reputation}</span>`:attrs.reputation<0?`<span style="color:var(--red)">${attrs.reputation}</span>`:'0'):null],
  ];
  if (type==='hash') return [
    ['SHA-256',`<span style="font-size:11px">${attrs.sha256||ioc}</span>`],
    ['SHA-1',`<span style="font-size:11px">${attrs.sha1||'—'}</span>`],
    ['MD5',attrs.md5||null],
    ['File Name',(attrs.names||[]).slice(0,2).join(', ')||null],
    ['File Type',attrs.type_description||attrs.magic||null],
    ['File Size',attrs.size?(attrs.size/1024).toFixed(1)+' KB':null],
    ['First Seen',attrs.first_submission_date?new Date(attrs.first_submission_date*1000).toLocaleDateString():null],
    ['Last Analysis',attrs.last_analysis_date?new Date(attrs.last_analysis_date*1000).toLocaleString():null],
    ['Times Sub.',attrs.times_submitted!==undefined?attrs.times_submitted.toLocaleString():null],
  ];
  if (type==='url') return [
    ['URL',`<span style="font-size:11px;word-break:break-all">${ioc}</span>`],
    ['Final URL',`<span style="font-size:11px">${attrs.last_final_url||'—'}</span>`],
    ['HTTP Status',attrs.last_http_response_code||null],
    ['Content Type',attrs.last_http_response_content_type||null],
    ['Title',attrs.title||null],
    ['First Sub.',attrs.first_submission_date?new Date(attrs.first_submission_date*1000).toLocaleDateString():null],
    ['Last Analysis',attrs.last_analysis_date?new Date(attrs.last_analysis_date*1000).toLocaleString():null],
    ['Reputation',attrs.reputation!==undefined?attrs.reputation:null],
  ];
  return [['IOC',ioc]];
}

// ── HISTORY ────────────────────────────────────────────────────────────────────
function addToHistory(rec) {
  // strip large attrs for storage
  const slim = { ioc:rec.ioc, type:rec.type, verdict:rec.verdict, malicious:rec.malicious,
    suspicious:rec.suspicious, total:rec.total, country:rec.country,
    stats:rec.stats, timestamp:rec.timestamp };
  scanHistory.unshift(slim);
  if (scanHistory.length>100) scanHistory=scanHistory.slice(0,100);
  localStorage.setItem('vt_history', JSON.stringify(scanHistory));
}
function renderHistory() {
  const el = document.getElementById('history-list');
  if (!scanHistory.length) { el.innerHTML='<div class="empty-state"><div class="empty-icon">📋</div><div>No scans yet.</div></div>'; return; }
  el.innerHTML = scanHistory.map((rec,i) => {
    const col={malicious:'var(--red)',suspicious:'var(--orange)',clean:'var(--green)',unknown:'var(--text3)'}[rec.verdict];
    const lbl={malicious:'🔴 Malicious',suspicious:'🟠 Suspicious',clean:'🟢 Clean',unknown:'❓ Unknown'}[rec.verdict];
    return `<div class="history-item" onclick="reloadScan('${rec.ioc.replace(/'/g,"\\'")}','${rec.type}')">
      <span class="history-type">${rec.type}</span>
      <span class="history-ioc">${rec.ioc}</span>
      <span class="history-verdict" style="color:${col}">${lbl}</span>
      <span class="history-date">${new Date(rec.timestamp).toLocaleString()}</span>
    </div>`;
  }).join('');
}
function reloadScan(ioc, type) {
  showPage('scan'); setType(type);
  document.getElementById('ioc-input').value = ioc;
  onIOCInput(ioc);
  toast('🔁 Press Scan to re-query VirusTotal for this IOC.');
}
function clearHistory() {
  if (confirm('Clear all scan history?')) {
    scanHistory=[]; localStorage.removeItem('vt_history');
    renderHistory(); renderDashboard(); toast('History cleared.');
  }
}

// ── DASHBOARD ─────────────────────────────────────────────────────────────────
function renderDashboard() {
  const total=scanHistory.length;
  const malicious=scanHistory.filter(r=>r.verdict==='malicious').length;
  const suspicious=scanHistory.filter(r=>r.verdict==='suspicious').length;
  const clean=scanHistory.filter(r=>r.verdict==='clean').length;
  const ips=scanHistory.filter(r=>r.type==='ip').length;
  const hashes=scanHistory.filter(r=>r.type==='hash').length;
  const urls=scanHistory.filter(r=>r.type==='url').length;
  document.getElementById('dash-stats').innerHTML=`
    <div class="stat-card"><div class="stat-num" style="color:var(--accent)">${total}</div><div class="stat-lbl">Total Scans</div></div>
    <div class="stat-card"><div class="stat-num" style="color:var(--red)">${malicious}</div><div class="stat-lbl">Malicious</div></div>
    <div class="stat-card"><div class="stat-num" style="color:var(--orange)">${suspicious}</div><div class="stat-lbl">Suspicious</div></div>
    <div class="stat-card"><div class="stat-num" style="color:var(--green)">${clean}</div><div class="stat-lbl">Clean</div></div>`;
  if (!total) { document.getElementById('dash-charts').innerHTML='<div class="empty-state" style="grid-column:1/-1"><div class="empty-icon">📊</div><div>Scan IOCs to see analytics.</div></div>'; return; }
  const recent=scanHistory.slice(0,10).reverse();
  document.getElementById('dash-charts').innerHTML=`
    <div class="card">
      <div class="card-title">📊 IOC Type Breakdown</div>
      <div class="cat-bar-wrap">
        ${[['IP Addresses',ips,'#63b3ed'],['File Hashes',hashes,'#b794f4'],['URLs',urls,'#f6ad55']].map(([l,v,c])=>`
        <div class="cat-bar-row">
          <div class="cat-bar-lbl">${l}</div>
          <div class="cat-bar-track"><div class="cat-bar-fill" style="width:${total>0?Math.round((v/total)*100):0}%;background:${c}"></div></div>
          <div class="cat-bar-num">${v}</div>
        </div>`).join('')}
      </div>
    </div>
    <div class="card">
      <div class="card-title">🕐 Recent Scans</div>
      <div style="display:flex;flex-direction:column;gap:6px">
        ${recent.map(r=>{const c={malicious:'red',suspicious:'orange',clean:'green',unknown:'gray'}[r.verdict];return`<div style="display:flex;gap:8px;align-items:center"><span class="tag ${c}" style="font-size:10px">${r.verdict}</span><span style="font-family:var(--mono);font-size:11px;color:var(--text2);flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${r.ioc}</span><span style="font-size:10px;color:var(--text3)">${r.type}</span></div>`}).join('')}
      </div>
    </div>`;
}

// ── MAP ───────────────────────────────────────────────────────────────────────
// Country ISO2 → verdict aggregation
function buildCountryVerdicts() {
  const map = {}; // iso2 -> {malicious, suspicious, clean, unknown}
  scanHistory.filter(r=>r.type==='ip'&&r.country).forEach(r=>{
    const cc = r.country.toUpperCase();
    if (!map[cc]) map[cc]={malicious:0,suspicious:0,clean:0,unknown:0};
    map[cc][r.verdict] = (map[cc][r.verdict]||0) + 1;
  });
  const result = {};
  Object.entries(map).forEach(([cc,v])=>{
      if (v.malicious > 0) {
          result[cc] = 'malicious';
      }
      else if (v.suspicious > 0) {
          result[cc] = 'suspicious';
      }
      else if (v.clean > 0) {
          result[cc] = 'clean';
      }
      else {
          result[cc] = 'unknown';
      }
  }); 
  return result;
}

function countryFillColor(verdict) {

  switch (verdict) {

    case 'malicious':
      return '#ff0000';

    case 'suspicious':
      return '#ff9900';

    case 'clean':
      return '#00cc66';

    default:
      return '#cccccc';
  }

}

function addMapTiles() {

  if (!mapInstance) return;

  L.tileLayer(
    'https://tile.openstreetmap.org/{z}/{x}/{y}.png',
    {
      maxZoom: 19,
      noWrap: true,
      attribution: '© OpenStreetMap'
    }
  ).addTo(mapInstance);

}

function refreshMapTiles() {
  if (!mapInstance) return;
  mapInstance.eachLayer(l => { if (l._url) mapInstance.removeLayer(l); });
  addMapTiles();
  if (geoJsonLayer) {
    mapInstance.removeLayer(geoJsonLayer);
    geoJsonLayer = null;
  }
  updateMapLayers();
}

async function initMap() {
  if (!mapInstance) {

    mapInstance = L.map('ip-map', {
      center: [20, 0],
      zoom: 2,
      minZoom: 2,
      worldCopyJump: false,
      maxBounds: [
        [-90, -180],
        [90, 180]
      ],
      maxBoundsViscosity: 1.0
    });

    addMapTiles();
  }

  setTimeout(() => {
    mapInstance.invalidateSize();
    updateMapLayers();
  }, 100);
}

async function updateMapLayers() {
  if (!mapInstance) return;

  // Remove old markers
  mapLayers.forEach(l=>mapInstance.removeLayer(l)); mapLayers=[];
  if (geoJsonLayer) { mapInstance.removeLayer(geoJsonLayer); geoJsonLayer=null; }

  const countryVerdicts = buildCountryVerdicts();
  const ipScans = scanHistory.filter(r=>r.type==='ip');

  // Render IP list
  const listEl = document.getElementById('ip-list');
  listEl.innerHTML = ipScans.length===0
    ? '<div class="empty-state"><div class="empty-icon">🌐</div><div>No IPs scanned yet.</div></div>'
    : ipScans.map(r=>{
        const col={malicious:'var(--red)',suspicious:'var(--orange)',clean:'var(--green)',unknown:'var(--text3)'}[r.verdict];
        return `<div class="history-item"><span class="history-type">IP</span><span class="history-ioc">${r.ioc}</span><span style="font-size:11px;color:var(--text2)">${r.country||'—'}</span><span class="history-verdict" style="color:${col}">${r.verdict}</span><span class="history-date">${new Date(r.timestamp).toLocaleDateString()}</span></div>`;
      }).join('');

  // Load GeoJSON world map and color countries
  if (Object.keys(countryVerdicts).length > 0) {
    try {
      const resp = await fetch('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json');
      const topo = await resp.json();
      // Convert topojson to geojson using simple approach
      const geojson = await fetch('https://raw.githubusercontent.com/datasets/geo-countries/master/data/countries.geojson');
      // Fallback: use a simpler country boundary source
      const gj = await geojson.json();
      geoJsonLayer = L.geoJSON(gj, {
        style: feature => {
          const iso =
            feature.properties.ISO_A2 ||
            feature.properties.iso_a2 ||
            feature.properties.ISO2 ||
          '';
          const verdict = countryVerdicts[iso.toUpperCase()];
          if (!verdict) return { fillColor:'transparent', fillOpacity:0, color:'transparent', weight:0 };
          return {
              fillColor: countryFillColor(verdict),
              fillOpacity: 0.75,
              color: countryFillColor(verdict),
              weight: 2,
              opacity: 1
          };
        },
        onEachFeature: (feature, layer) => {

        console.log(feature.properties);

        const iso =
            feature.properties.ISO_A2 ||
            feature.properties.iso_a2 ||
            feature.properties.ISO2 ||
            feature.properties.ADM0_A3 ||
            '';

        const verdict = countryVerdicts[iso.toUpperCase()];

        if (!verdict) return;

        layer.bindPopup(
            `${feature.properties.ADMIN || feature.properties.name}
            (${iso})<br>
            Verdict: ${verdict}`
        );

        }
      }).addTo(mapInstance);
    } catch(e) {
      // Fallback: just use point markers with larger radius if geo fails
    }
  }

  // Plot individual IP points via geo lookup
  for (const r of ipScans) {
    try {
      const geo = await fetch(`https://ipapi.co/${r.ioc}/json/`);
      const gd = await geo.json();
      if (gd.latitude && gd.longitude) {
        const color = {malicious:'#fc8181',suspicious:'#f6ad55',clean:'#68d391',unknown:'#94a3b8'}[r.verdict];
        const m = L.circleMarker([gd.latitude, gd.longitude], {
          radius:9, fillColor:color, color:'#fff',
          weight:2, opacity:1, fillOpacity:0.9
        }).addTo(mapInstance);
        m.bindPopup(`<strong>${r.ioc}</strong><br>Verdict: <span style="color:${color}">${r.verdict}</span><br>Country: ${gd.country_name||r.country||'—'}<br>City: ${gd.city||'—'}<br>ASN: ${gd.org||'—'}`);
        mapLayers.push(m);
        await sleep(200); // gentle rate limit on ipapi (free tier)
      }
    } catch{}
  }
}

// ── UTILS ─────────────────────────────────────────────────────────────────────
function showLoader(show, msg) {
  document.getElementById('scan-loader').style.display = show?'block':'none';
  if (msg) document.getElementById('scan-msg').textContent=msg;
  document.getElementById('scan-btn').disabled=show;
}
function toast(msg) {
  const el=document.getElementById('toast');
  el.textContent=msg; el.classList.add('show');
  setTimeout(()=>el.classList.remove('show'),3500);
}

window.addEventListener('load', ()=>{
  const k=localStorage.getItem('vt_api_key')||'';
  if (k) { document.getElementById('api-key-input').value=k; document.getElementById('settings-api-key').value=k; }
});
</script>
